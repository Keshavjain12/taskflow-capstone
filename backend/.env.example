
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://capstone:capstone@localhost:5432/capstone_db
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
